// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model usuarios {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  senha         String
  nome          String
  carteira      carteira?
  depositos     Deposito[]
  movimentacaos Movimentacao[]
}

model carteira {
  id         Int         @id @default(autoincrement())
  usuario    usuarios    @relation(fields: [usuarioId], references: [id])
  usuarioId  Int         @unique
  saldo      saldo[]
  transacaos Transacao[]
}

model saldo {
  id         Int        @id @default(autoincrement())
  quantidade Decimal
  carteira   carteira   @relation(fields: [carteiraid], references: [id])
  carteiraid Int
  tipo       tipo_valor

  @@unique([carteiraid, tipo])
}

enum tipo_valor {
  BRL
  BTC
  ETH
}

model Deposito {
  id             Int        @id @default(autoincrement())
  usuario        usuarios   @relation(fields: [usuarioId], references: [id])
  usuarioId      Int
  token          tipo_valor
  amount         Int
  idempotencyKey String     @unique
  createAt       DateTime   @default(now())
}

enum Tipo_Transacao {
  DEPOSITO
  SWAP
  WITHDRAWAL
}

model Transacao {
  id         Int            @id @default(autoincrement())
  tipo       Tipo_Transacao
  carteira   carteira       @relation(fields: [carteiraId], references: [id])
  carteiraId Int
  tokenFrom  tipo_valor?
  tokenTo    tipo_valor?
  valorFrom  Decimal?
  valorTo    Decimal?
  taxa       Decimal?
  dataHora   DateTime       @default(now())
}

enum Tipo_Movimentacao {
  DEPOSIT
  SWAP_IN
  SWAP_OUT
  SWAP_FEE
  WITHDRAWAL
}

model Movimentacao {
  id            Int               @id @default(autoincrement())
  tipo          Tipo_Movimentacao
  feitoPor      usuarios          @relation(fields: [usuarioId], references: [id])
  usuarioId     Int
  token         tipo_valor
  valor         Decimal
  saldoAnterior Decimal
  saldoNovo     Decimal
  dataHora      DateTime          @default(now())
}
